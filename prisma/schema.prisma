datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma-client"
}

enum Role {
  ADMIN
  VENDEDOR
  CLIENTE
}

enum EstadoVenta {
  PENDIENTE_LIQUIDACION
  LIQUIDADA
}

enum ReceptorPago {
  ADMIN
  VENDEDOR
}

model User {
  id                  Int                  @id @default(autoincrement())
  email               String?              @unique
  cedula              String?              @unique
  telefono            String?              @unique
  password            String
  role                Role                 @default(CLIENTE)
  nombre              String
  totalVapesComprados Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  inventariosVendedor InventarioVendedor[] // Para vendedores
  ventasRealizadas    Venta[]              @relation("VendedorVenta") // Ventas hechas por el vendedor
  ventasCompradas     Venta[]              @relation("ClienteVenta") // Compras del cliente
  suscripcion         Suscripcion?
  logros              LogroFidelidad[]
  liquidaciones       Liquidacion[]        @relation("VendedorLiquidacion")
  entregasSuscripcion EntregaSuscripcion[] // Entregas hechas por el vendedor
}

model Vape {
  id          Int                  @id @default(autoincrement())
  nombre      String
  descripcion String?
  imagenUrl   String?
  costo       Float
  precio      Float
  stockGlobal Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  inventarios InventarioVendedor[]
  Venta       Venta[]
  entregas    EntregaSuscripcion[]
}

model InventarioVendedor {
  id         Int      @id @default(autoincrement())
  vendedorId Int
  vapeId     Int
  cantidad   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  vendedor User @relation(fields: [vendedorId], references: [id])
  vape     Vape @relation(fields: [vapeId], references: [id])

  @@unique([vendedorId, vapeId])
}

model Venta {
  id                Int      @id @default(autoincrement())
  vendedorId        Int
  clienteId         Int?     // Opcional si es una venta rápida sin registrar cliente
  vapeId            Int
  cantidad          Int
  costoAdquisicion  Float    // Snapshot del costo en el momento de la venta
  precioVenta       Float    // Precio al que se vendió finalmente (con o sin descuento)
  descuentoAdmin    Float    @default(0) // Monto del descuento absorbido por el admin
  descuentoVendedor Float    @default(0) // Monto del descuento absorbido por el vendedor
  montoParaAdmin    Float    @default(0)
  montoParaVendedor Float    @default(0)
  pagadoA           ReceptorPago @default(VENDEDOR)
  estado            EstadoVenta @default(PENDIENTE_LIQUIDACION)
  comprobanteUrl    String?
  liquidacionId     Int?
  createdAt         DateTime @default(now())

  vendedor    User         @relation("VendedorVenta", fields: [vendedorId], references: [id])
  cliente     User?        @relation("ClienteVenta", fields: [clienteId], references: [id])
  vape        Vape         @relation(fields: [vapeId], references: [id])
  liquidacion Liquidacion? @relation(fields: [liquidacionId], references: [id])
}

model Liquidacion {
  id         Int      @id @default(autoincrement())
  vendedorId Int
  montoTotal Float    @default(0)
  cerrada    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  vendedor User    @relation("VendedorLiquidacion", fields: [vendedorId], references: [id])
  ventas   Venta[]
}

model PlanSuscripcion {
  id                Int           @id @default(autoincrement())
  nombre            String
  diasEntreEntregas Int           @default(30)
  precio            Float         @default(0)
  limiteVapes       Int?          // Limite opcional de vapes por periodo
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  suscripciones     Suscripcion[]
}

model Suscripcion {
  id                Int      @id @default(autoincrement())
  clienteId         Int      @unique
  planId            Int?     // Referencia opcional si aún no migramos todos
  activa            Boolean  @default(true)
  diasEntreEntregas Int      @default(60) // Legacy
  multaFija         Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  cliente User @relation(fields: [clienteId], references: [id])
  plan    PlanSuscripcion? @relation(fields: [planId], references: [id])
  entregas EntregaSuscripcion[]
}

model EntregaSuscripcion {
  id             Int      @id @default(autoincrement())
  suscripcionId  Int
  vendedorId     Int
  vapeId         Int
  multaAplicada  Float    @default(0)
  createdAt      DateTime @default(now())

  suscripcion    Suscripcion @relation(fields: [suscripcionId], references: [id])
  vendedor       User        @relation(fields: [vendedorId], references: [id])
  vape           Vape        @relation(fields: [vapeId], references: [id])
}

model LogroFidelidad {
  id          Int      @id @default(autoincrement())
  clienteId   Int
  nombre      String
  descripcion String?
  obtenidoEn  DateTime @default(now())

  cliente User @relation(fields: [clienteId], references: [id])
}
